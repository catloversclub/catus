{
  "expo": {
    "name": "Catus",
    "slug": "catus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/android.png",
    "scheme": "catus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.catloversclub.catus",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": {
        "dark": "./assets/images/logo/ios-dark.png",
        "light": "./assets/images/logo/ios-light.png"
      }
    },
    "android": {
      // "adaptiveIcon": {
      //   "backgroundColor": "#FFF",
      //   "foregroundImage": "./assets/images/android-icon-foreground.png",
      //   "backgroundImage": "./assets/images/android-icon-background.png",
      //   "monochromeImage": "./assets/images/android-icon-monochrome.png"
      // },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.catloversclub.catus",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo/android.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF",
          "image": "./assets/images/logo/col-light.png",
          "dark": {
            "image": "./assets/images/logo/col-dark.png",
            "backgroundColor": "#000"
          },
          "imageWidth": 200
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "510bc3970b990aa960265ab40e5c434b",
          "kotlinVersion": "1.9.0"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": ["https://devrepo.kakao.com/nexus/content/groups/public/"]
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.173729862302-hijqsljupaf8j2s7608uohn41rek3bnr"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "고양이 사진에 접근하여 친구들과 공유할 수 있습니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60dff609-0ea9-49e9-a976-eaa8b9764820"
      }
    },
    "owner": "minngyuseong"
  }
}
